# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
*.local

# Tauri build artifacts
src-tauri/target/
src-tauri/gen/schemas/
src-tauri/tauri-dev.log
src-tauri/lipi-window.png
# screenshot.ps1 is a dev helper; keep it tracked so contributors can use it

# Tauri updater signing keys
# The .key.pub (public) is committed so `cargo tauri build` works
# out of the box for contributors. The .key (private) is a dev
# placeholder with a hard-coded password — production CI rotates
# to a real key from a secret store, never commits the private
# key.
lipi-dev.key
!lipi-dev.key.pub

# Logs
logs/
*.log
verify/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.cursor/

# OS
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# Env / secrets
.env
.env.local
.env.*.local

# Coverage / cache
coverage/
.cache/
.turbo/
.parcel-cache/

# Lockfile for non-npm package managers (we use npm)
yarn.lock
pnpm-lock.yaml
bun.lockb

# Session debris — verification output files left
# behind by `git add .` after a run of `cargo test`
# / `npm run build` / etc. They are not source.
build-*.txt
build_log.txt
out.txt
