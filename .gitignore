# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
*.local

# Tauri build artifacts
src-tauri/target/
# target-m2c/ is the parallel CARGO_TARGET_DIR used
# for the m2c-native (whisper-rs-sys) builds. It's
# a build artifact, not source.
src-tauri/target-m2c/
src-tauri/gen/schemas/
src-tauri/tauri-dev.log
src-tauri/lipi-window.png
# screenshot.ps1 is a dev helper; keep it tracked so contributors can use it

# Tauri updater signing keys
# - production/ holds production public material only. The .pub
#   is committed so the embedded `plugins.updater.pubkey` in
#   tauri.conf.json matches the CI signing key (so end users
#   can verify update signatures). Production private keys must
#   live outside the repo tree in CI secrets + an offline vault;
#   the ignore rules below are a backstop, not a storage policy.
# - dev/ holds a *throwaway* dev keypair. The .pub is committed
#   so contributors can run `tauri build` locally without
#   setting up signing secrets. The .key (private) is
#   git-ignored — never reuse the dev key for any artifact
#   that ships to users.
src-tauri/keys/production/*.key
src-tauri/keys/production/*.key.txt
!src-tauri/keys/production/*.key.pub
src-tauri/keys/dev/*.key
!src-tauri/keys/dev/*.key.pub
# Backwards-compat: any old `lipi-dev.key` at the
# src-tauri/ root is also ignored.
lipi-dev.key
# Backwards-compat: root-level .pub is a legacy
# leftover — the canonical copy lives at
# src-tauri/keys/dev/lipi-dev.key.pub.
/lipi-dev.key.pub

