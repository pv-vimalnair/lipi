coverage/
.cache/
.turbo/
.parcel-cache/

# Lockfile for non-npm package managers (we use npm)
yarn.lock
pnpm-lock.yaml
bun.lockb

# Session debris — verification output files left
# behind by `git add .` after a run of `cargo test`
# / `npm run build` / etc. They are not source.
build-*.txt
build_log.txt
out.txt
verify/
status.txt

# Temporary files — screenshots, data dumps, and
# one-off scripts generated during development.
.tmp-*
/build-with-key.ps1
/try_build.ps1
/verify.ps1
/serve-mocks.js
/msvc_run.bat

# TypeScript incremental build cache
# (`tsc -b` regenerates this on every run; it's
# noise in `git status` and slows down the index.)
tsconfig.tsbuildinfo
